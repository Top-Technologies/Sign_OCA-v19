<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for HR Documents -->
        <record id="seq_sign_oca_hr" model="ir.sequence">
            <field name="name">HR Document Sequence</field>
            <field name="code">sign.oca.hr.sequence</field>
            <field name="prefix">TSST-HCA-</field>
            <field name="suffix">-2018</field>
            <field name="padding">3</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sign Field for Document Sequence -->
        <record id="sign_field_document_sequence" model="sign.oca.field">
            <field name="name">Document Sequence</field>
            <field name="field_type">text</field>
            <field name="default_value"></field>
        </record>
    </data>
</odoo>
